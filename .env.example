# App
PORT=3090
APP_TITLE=Mesh Health Check
APP_EYEBROW=MeshCore Observer Coverage
APP_HEADLINE=Check your mesh reach.
APP_DESCRIPTION=Generate a test code, send it to the configured channel, and watch observer coverage build in real time.
EXTERNAL_LINK_URL=
EXTERNAL_LINK_LABEL=
LOG_LEVEL=info
TRUST_PROXY=1

# Observer names
OBSERVERS_FILE=data/observer.json
RESULTS_FILE=data/session-results.json

# Region detection — point the server at a GeoJSON FeatureCollection to enable
# region filter buttons in the observer panel. Granularity is determined by the
# boundary file: use regions/uk.geojson for UK regions, regions/us-states.geojson
# for US state-level filtering, regions/de-bundeslaender.geojson for Germany, etc.
# Leave blank to disable region detection entirely.
# REGIONS_FILE=regions/uk.geojson

# MQTT
MQTT_HOST=mqtt.example.net
MQTT_PORT=443
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=meshcore/SITE/#
MQTT_TRANSPORT=websockets
MQTT_WS_PATH=/
MQTT_TLS=true
MQTT_CLIENT_ID=
DASH_BROKER_HOST=

# Optional full MQTT URL override, for example:
# MQTT_URL=wss://host.example:443/mqtt
MQTT_URL=

# Optional repo-local channel file. Leave blank to use TEST_CHANNEL_SECRET only.
CHANNELS_FILE=

# Test channel
TEST_CHANNEL_NAME=test-channel
TEST_CHANNEL_SECRET=
TEST_CHANNEL_HASH=

# Session behavior
SESSION_TTL_SECONDS=600
RESULT_RETENTION_SECONDS=604800
MAX_USES_PER_CODE=3
SESSION_RATE_WINDOW_SECONDS=600
SESSION_RATE_MAX=30

# Default observer target
# Comma-separated full pubkeys. Leave blank to fall back to the active observer window.
KNOWN_OBSERVERS=
OBSERVER_ACTIVE_WINDOW_SECONDS=900
# Set to 0 to disable stale-observer pruning from the dashboard/map.
OBSERVER_RETENTION_SECONDS=0

# Turnstile
TURNSTILE_ENABLED=true
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_API_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
TURNSTILE_COOKIE_NAME=mesh_health_turnstile
TURNSTILE_TOKEN_TTL_SECONDS=86400
TURNSTILE_BOT_BYPASS=true
TURNSTILE_BOT_ALLOWLIST=discordbot,twitterbot,slackbot,facebookexternalhit,linkedinbot,telegrambot,whatsapp
TURNSTILE_VERIFY_RATE_WINDOW_SECONDS=600
TURNSTILE_VERIFY_RATE_MAX=10
